# Mapbox API token for map rendering
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Backboard.io API key for RAG/AI construction impact analysis (legacy)
VITE_BACKBOARD_API_KEY=your_backboard_api_key_here

# Moorcheh Memory SDK API key (community memory layer)
MOORCHEH_API_KEY=your_moorcheh_api_key_here

# Moorcheh service URL (default: http://localhost:8000)
# MOORCHEH_SERVICE_URL=http://localhost:8000
